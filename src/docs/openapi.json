{
  "openapi": "3.0.0",
  "info": {
    "title": "青衿智眼 API",
    "version": "1.0.0",
    "description": "青衿智眼-基于多模态感知的课堂专注度AI分析平台 API 文档，提供实时检测、专注度评分、历史与告警查询等能力。",
    "contact": {
      "name": "QingJin Vision Support",
      "email": "support@school-cream.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "本地开发服务器"
    },
    {
      "url": "https://api.school-cream.com",
      "description": "生产环境服务器"
    }
  ],
  "paths": {
    "/api/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "获取当前检测状态",
        "description": "获取系统的当前检测状态，包括人员数量、举手、躺卧、手机使用等实时数据，以及摄像头信息和系统状态。",
        "tags": ["检测状态"],
        "responses": {
          "200": {
            "description": "成功获取状态",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                },
                "example": {
                  "success": true,
                  "data": {
                    "current": {
                      "Person": 25,
                      "Raise Hand": 3,
                      "Lie Down": 0,
                      "Phone Usage": 1
                    },
                    "camera_info": {
                      "name": "前摄像头",
                      "course_name": "高等数学",
                      "room_id": "A101",
                      "status": "running"
                    },
                    "system_status": {
                      "running": true,
                      "frame_count": 1250,
                      "fps": 30
                    },
                    "last_update": "2024-01-15T14:30:00"
                  }
                }
              }
            }
          },
          "500": {
            "description": "服务器错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/history": {
      "get": {
        "operationId": "getHistory",
        "summary": "获取历史记录",
        "description": "获取系统的历史检测记录，支持限制返回记录数量。",
        "tags": ["历史记录"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "返回记录数量限制，默认100",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取历史记录",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/alerts": {
      "get": {
        "operationId": "getAlerts",
        "summary": "获取告警列表",
        "description": "获取系统的告警信息列表，包括异常行为（躺卧、手机使用）的告警记录。",
        "tags": ["告警"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "返回告警数量限制，默认50",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取告警列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlertsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/stats": {
      "get": {
        "operationId": "getStats",
        "summary": "获取统计数据",
        "description": "获取系统的统计数据，包括总帧数、各类行为的总计数和告警数量。",
        "tags": ["统计"],
        "responses": {
          "200": {
            "description": "成功获取统计数据",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/system/info": {
      "get": {
        "operationId": "getSystemInfo",
        "summary": "获取系统信息",
        "description": "获取系统的详细信息，包括摄像头信息和系统运行状态。",
        "tags": ["系统信息"],
        "responses": {
          "200": {
            "description": "成功获取系统信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemInfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/query": {
      "post": {
        "operationId": "queryData",
        "summary": "通用查询接口",
        "description": "通用的查询接口，供智能体调用。支持查询状态、告警、统计等不同类型的数据。",
        "tags": ["智能体查询"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              },
              "example": {
                "type": "status"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功查询数据",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "服务器错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "健康检查",
        "description": "检查API服务是否正常运行。",
        "tags": ["系统"],
        "responses": {
          "200": {
            "description": "服务正常",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "请求是否成功"
          },
          "data": {
            "type": "object",
            "properties": {
              "current": {
                "$ref": "#/components/schemas/DetectionCounts"
              },
              "camera_info": {
                "$ref": "#/components/schemas/CameraInfo"
              },
              "system_status": {
                "$ref": "#/components/schemas/SystemStatus"
              },
              "last_update": {
                "type": "string",
                "format": "date-time",
                "description": "最后更新时间"
              }
            }
          }
        }
      },
      "DetectionCounts": {
        "type": "object",
        "description": "检测计数",
        "properties": {
          "Person": {
            "type": "integer",
            "description": "人员数量"
          },
          "Raise Hand": {
            "type": "integer",
            "description": "举手人数"
          },
          "Lie Down": {
            "type": "integer",
            "description": "躺卧人数"
          },
          "Phone Usage": {
            "type": "integer",
            "description": "使用手机人数"
          }
        }
      },
      "CameraInfo": {
        "type": "object",
        "description": "摄像头信息",
        "properties": {
          "name": {
            "type": "string",
            "description": "摄像头名称"
          },
          "course_name": {
            "type": "string",
            "description": "课程名称"
          },
          "room_id": {
            "type": "string",
            "description": "教室ID"
          },
          "status": {
            "type": "string",
            "enum": ["running", "stopped"],
            "description": "运行状态"
          }
        }
      },
      "SystemStatus": {
        "type": "object",
        "description": "系统状态",
        "properties": {
          "running": {
            "type": "boolean",
            "description": "是否运行中"
          },
          "frame_count": {
            "type": "integer",
            "description": "已处理帧数"
          },
          "fps": {
            "type": "number",
            "description": "帧率"
          }
        }
      },
      "HistoryResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HistoryRecord"
            }
          },
          "total": {
            "type": "integer",
            "description": "总记录数"
          }
        }
      },
      "HistoryRecord": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "counts": {
            "$ref": "#/components/schemas/DetectionCounts"
          },
          "camera_info": {
            "$ref": "#/components/schemas/CameraInfo"
          }
        }
      },
      "AlertsResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Alert"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "type": {
            "type": "string",
            "description": "告警类型"
          },
          "details": {
            "type": "object",
            "properties": {
              "Lie Down": {
                "type": "integer"
              },
              "Phone Usage": {
                "type": "integer"
              }
            }
          },
          "camera_info": {
            "$ref": "#/components/schemas/CameraInfo"
          }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "total_frames": {
                "type": "integer",
                "description": "总帧数"
              },
              "total_person": {
                "type": "integer",
                "description": "总人员计数"
              },
              "total_raise_hand": {
                "type": "integer",
                "description": "总举手计数"
              },
              "total_lie_down": {
                "type": "integer",
                "description": "总躺卧计数"
              },
              "total_phone_usage": {
                "type": "integer",
                "description": "总手机使用计数"
              },
              "alert_count": {
                "type": "integer",
                "description": "告警数量"
              }
            }
          }
        }
      },
      "SystemInfoResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "camera_info": {
                "$ref": "#/components/schemas/CameraInfo"
              },
              "system_status": {
                "$ref": "#/components/schemas/SystemStatus"
              },
              "last_update": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "QueryRequest": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["status", "alerts", "stats"],
            "description": "查询类型：status-状态，alerts-告警，stats-统计"
          },
          "limit": {
            "type": "integer",
            "description": "限制返回数量（仅对alerts类型有效）",
            "default": 10
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "description": "查询结果数据，根据type不同而不同"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["healthy"],
            "description": "服务状态"
          },
          "service": {
            "type": "string",
            "description": "服务名称"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "default": false
          },
          "error": {
            "type": "string",
            "description": "错误信息"
          }
        }
      }
    }
  }
}

